diff --git a/src/wayland/handlers/gamma_control.rs b/src/wayland/handlers/gamma_control.rs
new file mode 100644
index 0000000..b6b7afd
--- /dev/null
+++ b/src/wayland/handlers/gamma_control.rs
@@ -0,0 +1,114 @@
+// SPDX-License-Identifier: GPL-3.0-only
+
+use smithay::{
+    output::Output,
+    reexports::drm::control::Device as ControlDevice,
+};
+
+use crate::{
+    backend::kms::Surface,
+    state::{BackendData, State},
+    wayland::protocols::gamma_control::{
+        GammaControlHandler, GammaControlState, delegate_gamma_control,
+    },
+};
+
+fn kms_surfaces(state: &mut State) -> impl Iterator<Item = &mut Surface> {
+    if let BackendData::Kms(kms_state) = &mut state.backend {
+        Some(
+            kms_state
+                .drm_devices
+                .values_mut()
+                .flat_map(|device| device.inner.surfaces.values_mut()),
+        )
+    } else {
+        None
+    }
+    .into_iter()
+    .flatten()
+}
+
+fn primary_kms_surface_for_output<'a>(
+    state: &'a mut State,
+    output: &Output,
+) -> Option<&'a mut Surface> {
+    kms_surfaces(state).find(|surface| surface.output == *output)
+}
+
+impl GammaControlHandler for State {
+    fn gamma_control_state(&mut self) -> &mut GammaControlState {
+        &mut self.common.gamma_control_state
+    }
+
+    fn get_gamma_size(&mut self, output: &Output) -> Option<u32> {
+        let surface = primary_kms_surface_for_output(self, output)?;
+        let crtc = surface.crtc();
+        if let BackendData::Kms(kms_state) = &self.backend {
+            for device in kms_state.drm_devices.values() {
+                if let Ok(info) = device.inner.gbm.get_crtc(crtc) {
+                    let len = info.gamma_length();
+                    if len > 1 {
+                        return Some(len);
+                    }
+                }
+            }
+        }
+        None
+    }
+
+    fn set_gamma(&mut self, output: &Output, ramp: Option<&[u16]>) -> bool {
+        let crtc = match primary_kms_surface_for_output(self, output) {
+            Some(surface) => surface.crtc(),
+            None => return false,
+        };
+
+        if let BackendData::Kms(kms_state) = &self.backend {
+            for device in kms_state.drm_devices.values() {
+                let gamma_size = match device.inner.gbm.get_crtc(crtc) {
+                    Ok(info) => info.gamma_length() as usize,
+                    Err(_) => continue,
+                };
+
+                if gamma_size <= 1 {
+                    return false;
+                }
+
+                let (red, green, blue): (Vec<u16>, Vec<u16>, Vec<u16>) = match ramp {
+                    Some(data) => {
+                        if data.len() != gamma_size * 3 {
+                            tracing::warn!(
+                                "Gamma ramp size mismatch: expected {}, got {}",
+                                gamma_size * 3,
+                                data.len()
+                            );
+                            return false;
+                        }
+                        (
+                            data[..gamma_size].to_vec(),
+                            data[gamma_size..gamma_size * 2].to_vec(),
+                            data[gamma_size * 2..].to_vec(),
+                        )
+                    }
+                    None => {
+                        // Restore linear gamma
+                        let linear: Vec<u16> = (0..gamma_size)
+                            .map(|i| ((i as u64 * 0xFFFF) / (gamma_size as u64 - 1)) as u16)
+                            .collect();
+                        (linear.clone(), linear.clone(), linear)
+                    }
+                };
+
+                match device.inner.gbm.set_gamma(crtc, &red, &green, &blue) {
+                    Ok(()) => return true,
+                    Err(e) => {
+                        tracing::warn!(?e, "Failed to set gamma ramp");
+                        return false;
+                    }
+                }
+            }
+        }
+        false
+    }
+}
+
+delegate_gamma_control!(State);
