Backport HTML markup parsing for the notifications applet body, mirroring
pop-os/cosmic-notifications#144 which was applied to cosmic-applets master
post epoch-1.0.11. Without this, notification bodies containing FreeDesktop
spec HTML tags (<b>, <i>, <u>, <a>) render as raw angle-bracket text in the
panel applet's notifications view.

The pinned cosmic-notifications-util dep (rev 6046bb29) already exposes the
markup module, so only the applet's render site changes. Hunk 2 deliberately
avoids the `cosmic::iced(_futures)?::futures::executor::block_on` line as
context since that import differs between epoch-1.0.10 and epoch-1.0.11.

--- a/cosmic-applet-notifications/src/lib.rs
+++ b/cosmic-applet-notifications/src/lib.rs
@@ -16,7 +16,7 @@
         Alignment, Length, Subscription,
         advanced::text::{Ellipsize, EllipsizeHeightLimit},
         platform_specific::shell::wayland::commands::popup::{destroy_popup, get_popup},
-        widget::{self, column, row},
+        widget::{self, column, rich_text, row},
         window,
     },
     surface, theme,
@@ -28,3 +28,3 @@
 use cosmic_notifications_config::NotificationsConfig;
-use cosmic_notifications_util::{ActionId, Image, Notification};
+use cosmic_notifications_util::{ActionId, Image, Notification, markup};
 use std::{borrow::Cow, collections::HashMap, path::PathBuf, sync::LazyLock};
@@ -456,8 +456,11 @@
                                     column![
                                         text::body(n.summary.lines().next().unwrap_or_default())
                                             .width(Length::Fill),
-                                        text::caption(n.body.lines().next().unwrap_or_default())
-                                            .width(Length::Fill)
+                                        Element::from(
+                                            rich_text(markup::html_to_spans(&n.body))
+                                                .size(12.0)
+                                                .width(Length::Fill)
+                                        )
                                     ]
                                 )
                                 .width(Length::Fill),
