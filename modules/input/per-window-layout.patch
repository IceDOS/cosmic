+fn target_surface(t: &KeyboardFocusTarget) -> Option<CosmicSurface> {
+    match t {
+        KeyboardFocusTarget::Element(m) => Some(m.active_window()),
+        KeyboardFocusTarget::Fullscreen(s) => Some(s.clone()),
+        _ => None,
+    }
+}
+
+fn sync_layout_indicator(state: &mut State, keymap_order: &[(String, String)], active: usize) {
+    use cosmic_config::ConfigSet;
+    let mut ordered = vec![keymap_order[active].clone()];
+    ordered.extend(keymap_order.iter().enumerate()
+        .filter(|(i, _)| *i != active).map(|(_, p)| p.clone()));
+    let mut cfg = state.common.config.cosmic_conf.xkb_config.clone();
+    cfg.layout = ordered.iter().map(|(l, _)| l.as_str()).collect::<Vec<_>>().join(",");
+    cfg.variant = ordered.iter().map(|(_, v)| v.as_str()).collect::<Vec<_>>().join(",");
+    state.common.config.cosmic_conf.xkb_config = cfg.clone();
+    state.common.ignore_xkb_config_changes.fetch_add(1, std::sync::atomic::Ordering::SeqCst);
+    let _ = state.common.config.cosmic_helper.set("xkb_config", &cfg);
+}
